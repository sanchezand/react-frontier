{
	"compilerOptions": {
		"target": "ES2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"lib": [
			"dom",
			"dom.iterable",
			"esnext"
		],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"strictNullChecks": false,
		"forceConsistentCasingInFileNames": true,
		"noFallthroughCasesInSwitch": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"outDir": "./dist"
		// "types": ["./types.d.ts"]
	},
	"include": [
		"src",
		"./types.d.ts"
	]
}
